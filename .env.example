# ──────────── 本地开发 ────────────
DATABASE_URL="file:./prisma/dev.db"
JWT_SECRET="dev-secret-change-in-production"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ──────────── 数据库（三选一）────────────
# 生产环境必须配 Turso（免费的 SQLite 云服务）
# DATABASE_URL="libsql://codejourney-xxx.turso.io"
# TURSO_AUTH_TOKEN="eyJ..."

# ──────────── 文件存储（三选一）────────────
# 【方式 1: 腾讯云 COS（EdgeOne Pages 推荐）】
# COS_SECRET_ID="你的 SecretId"
# COS_SECRET_KEY="你的 SecretKey"
# COS_BUCKET="codejourney-xxx"
# COS_REGION="ap-guangzhou"

# 【方式 2: Vercel Blob（Vercel 部署用，Dashboard 自动注入）】
# BLOB_READ_WRITE_TOKEN=""

# 【方式 3: 本地磁盘（开发默认）】
# 不填任何文件存储变量即可走本地

# ──────────── 定时任务密钥 ────────────
# CRON_SECRET="随机32位字符串"

# ──────────── 邮件（可选）────────────
# SMTP_HOST="smtp.qq.com"
# SMTP_PORT=587
# SMTP_USER="xxx@qq.com"
# SMTP_PASS="xxx"
# SMTP_FROM="码途 <xxx@qq.com>"
